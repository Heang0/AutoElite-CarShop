# ===================================
# ENVIRONMENT VARIABLES EXAMPLE
# ===================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub!

# ===================================
# FIREBASE CONFIGURATION
# ===================================
# Get these from Firebase Console → Project Settings → General → Your apps
FIREBASE_API_KEY="YOUR_API_KEY_HERE"
FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
FIREBASE_APP_ID="YOUR_APP_ID"
FIREBASE_MEASUREMENT_ID="YOUR_MEASUREMENT_ID"

# ===================================
# ADMIN CREDENTIALS
# ===================================
# Change these to your actual admin credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# ===================================
# CLOUDINARY (Image Upload)
# ===================================
# Get from Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# ===================================
# BACKEND API
# ===================================
API_BASE_URL="http://127.0.0.1:4000/api"

# ===================================
# MONGODB (Backend Only)
# ===================================
# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# ===================================
# BAKONG KHQR (Backend Only)
# ===================================
# Bakong merchant credentials
BAKONG_ACCOUNT_ID="your-bakong-account-id"
BAKONG_MERCHANT_NAME="Your Merchant Name"
BAKONG_MERCHANT_CITY="Phnom Penh"
BAKONG_STORE_LABEL="STORE-A"
BAKONG_TERMINAL_LABEL="TERMINAL-A"
BAKONG_ENV="production"
BAKONG_MOCK="false"
BAKONG_TOKEN="your-bakong-api-token"
